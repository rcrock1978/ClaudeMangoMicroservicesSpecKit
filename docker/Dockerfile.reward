# Multi-stage Dockerfile for Mango.Services.Reward.API
# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /src

# Copy csproj files and restore dependencies
COPY ["src/Reward/API/Mango.Services.Reward.API/Mango.Services.Reward.API.csproj", "src/Reward/API/Mango.Services.Reward.API/"]
COPY ["src/Reward/Application/Mango.Services.Reward.Application/Mango.Services.Reward.Application.csproj", "src/Reward/Application/Mango.Services.Reward.Application/"]
COPY ["src/Reward/Domain/Mango.Services.Reward.Domain/Mango.Services.Reward.Domain.csproj", "src/Reward/Domain/Mango.Services.Reward.Domain/"]
COPY ["src/Reward/Infrastructure/Mango.Services.Reward.Infrastructure/Mango.Services.Reward.Infrastructure.csproj", "src/Reward/Infrastructure/Mango.Services.Reward.Infrastructure/"]
COPY ["src/Reward/Reward/Mango.Services.Reward.Reward/Mango.Services.Reward.Reward.csproj", "src/Reward/Reward/Mango.Services.Reward.Reward/"]

# Copy MessageBus for shared events
COPY ["src/Mango.MessageBus/Mango.MessageBus.csproj", "src/Mango.MessageBus/"]

RUN dotnet restore "src/Reward/API/Mango.Services.Reward.API/Mango.Services.Reward.API.csproj"

# Copy everything else and build
COPY . .
WORKDIR "/src/src/Reward/API/Mango.Services.Reward.API"
RUN dotnet build "Mango.Services.Reward.API.csproj" -c Release -o /app/build

# Publish stage
FROM build AS publish
RUN dotnet publish "Mango.Services.Reward.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0-alpine AS final
WORKDIR /app

# Create non-root user
RUN addgroup -g 1000 dotnet && \
    adduser -u 1000 -G dotnet -s /bin/sh -D dotnet

# Copy published app
COPY --from=publish /app/publish .

# Change ownership to non-root user
RUN chown -R dotnet:dotnet /app
USER dotnet

EXPOSE 80
EXPOSE 443

ENTRYPOINT ["dotnet", "Mango.Services.Reward.API.dll"]