# Multi-stage Dockerfile for Mango.Services.ShoppingCart.API
# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /src

# Copy csproj files and restore dependencies
COPY ["src/ShoppingCart/API/Mango.Services.ShoppingCart.API/Mango.Services.ShoppingCart.API.csproj", "src/ShoppingCart/API/Mango.Services.ShoppingCart.API/"]
COPY ["src/ShoppingCart/Application/Mango.Services.ShoppingCart.Application/Mango.Services.ShoppingCart.Application.csproj", "src/ShoppingCart/Application/Mango.Services.ShoppingCart.Application/"]
COPY ["src/ShoppingCart/Domain/Mango.Services.ShoppingCart.Domain/Mango.Services.ShoppingCart.Domain.csproj", "src/ShoppingCart/Domain/Mango.Services.ShoppingCart.Domain/"]
COPY ["src/ShoppingCart/Infrastructure/Mango.Services.ShoppingCart.Infrastructure/Mango.Services.ShoppingCart.Infrastructure.csproj", "src/ShoppingCart/Infrastructure/Mango.Services.ShoppingCart.Infrastructure/"]
COPY ["src/ShoppingCart/ShoppingCart/Mango.Services.ShoppingCart.ShoppingCart/Mango.Services.ShoppingCart.ShoppingCart.csproj", "src/ShoppingCart/ShoppingCart/Mango.Services.ShoppingCart.ShoppingCart/"]

# Copy MessageBus for shared events
COPY ["src/Mango.MessageBus/Mango.MessageBus.csproj", "src/Mango.MessageBus/"]

RUN dotnet restore "src/ShoppingCart/API/Mango.Services.ShoppingCart.API/Mango.Services.ShoppingCart.API.csproj"

# Copy everything else and build
COPY . .
WORKDIR "/src/src/ShoppingCart/API/Mango.Services.ShoppingCart.API"
RUN dotnet build "Mango.Services.ShoppingCart.API.csproj" -c Release -o /app/build

# Publish stage
FROM build AS publish
RUN dotnet publish "Mango.Services.ShoppingCart.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0-alpine AS final
WORKDIR /app

# Create non-root user
RUN addgroup -g 1000 dotnet && \
    adduser -u 1000 -G dotnet -s /bin/sh -D dotnet

# Copy published app
COPY --from=publish /app/publish .

# Change ownership to non-root user
RUN chown -R dotnet:dotnet /app
USER dotnet

EXPOSE 80
EXPOSE 443

ENTRYPOINT ["dotnet", "Mango.Services.ShoppingCart.API.dll"]