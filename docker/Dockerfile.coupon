# Multi-stage Dockerfile for Mango.Services.Coupon.API
# Build stage
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /src

# Copy csproj files and restore dependencies
COPY ["src/Coupon/API/Mango.Services.Coupon.API/Mango.Services.Coupon.API.csproj", "src/Coupon/API/Mango.Services.Coupon.API/"]
COPY ["src/Coupon/Application/Mango.Services.Coupon.Application/Mango.Services.Coupon.Application.csproj", "src/Coupon/Application/Mango.Services.Coupon.Application/"]
COPY ["src/Coupon/Domain/Mango.Services.Coupon.Domain/Mango.Services.Coupon.Domain.csproj", "src/Coupon/Domain/Mango.Services.Coupon.Domain/"]
COPY ["src/Coupon/Infrastructure/Mango.Services.Coupon.Infrastructure/Mango.Services.Coupon.Infrastructure.csproj", "src/Coupon/Infrastructure/Mango.Services.Coupon.Infrastructure/"]

RUN dotnet restore "src/Coupon/API/Mango.Services.Coupon.API/Mango.Services.Coupon.API.csproj"

# Copy everything else and build
COPY . .
WORKDIR "/src/src/Coupon/API/Mango.Services.Coupon.API"
RUN dotnet build "Mango.Services.Coupon.API.csproj" -c Release -o /app/build

# Publish stage
FROM build AS publish
RUN dotnet publish "Mango.Services.Coupon.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Runtime stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0-alpine AS final
WORKDIR /app

# Create non-root user
RUN addgroup -g 1000 dotnet && \
    adduser -u 1000 -G dotnet -s /bin/sh -D dotnet

# Copy published app
COPY --from=publish /app/publish .

# Change ownership to non-root user
RUN chown -R dotnet:dotnet /app
USER dotnet

EXPOSE 80
EXPOSE 443

ENTRYPOINT ["dotnet", "Mango.Services.Coupon.API.dll"]